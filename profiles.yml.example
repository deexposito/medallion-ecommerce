# Copy this file to `profiles.yml` (gitignored) at the project root,
# or to ~/.dbt/profiles.yml as is customary for dbt.
#
# DuckDB needs no server or credentials: the "database" is simply a local
# file (.duckdb) that gets created automatically the first time you run
# `dbt run`.

medallion_ecommerce:
  target: dev
  outputs:
    dev:
      type: duckdb
      path: 'medallion.duckdb'
      threads: 4
